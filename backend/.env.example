# Telegram Notification
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-100123456789

# AI Caption / SEO Title Generator (console.anthropic.com থেকে নিন)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# App
DEFAULT_CAPTION=AutoPost Pro দ্বারা প্রকাশিত 🚀
SECRET_KEY=change-this-to-a-random-secret-string
FLASK_DEBUG=false
PORT=5000

# Admin Login (dashboard-এ ঢোকার জন্য — প্রথমে এটাই দিয়ে লগইন করুন, পরে Settings থেকে বদলানো যাবে)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# Facebook OAuth Login-এর জন্য — backend ও frontend এর public URL (Railway/Netlify deploy করার পর বসান)
BACKEND_PUBLIC_URL=https://your-backend.up.railway.app
FRONTEND_URL=https://your-app.netlify.app

# Google Drive (Service Account JSON - paste full JSON as one line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
